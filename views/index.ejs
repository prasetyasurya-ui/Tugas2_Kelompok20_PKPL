<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Biodata Kelompok</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="<%= theme.background %> <%= theme.font %> p-10 relative">

    <div class="absolute top-5 right-5 flex items-center space-x-4">
        <% if (!user) { %>
            <a href="/auth/google" class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-2 rounded shadow">
                Login with Google
            </a>
        <% } else { %> 
            <div class="flex items-center space-x-3 bg-white px-4 py-2 rounded-full shadow-sm">
                <span class="font-semibold text-gray-500 text-sm"><%= user.displayName %></span>
                <a href="/logout" class="bg-red-500 hover:bg-red-600 text-gray-700 px-3 py-2 rounded shadow">
                    Logout
                </a>
            </div>
        <% } %>
    </div>

    <h1 class="text-3xl font-bold text-center mb-8">
        Selamat Datang di <%= namaKelompok %>
    </h1>

    <div class="bg-white p-6 rounded-lg shadow-md max-w-md mx-auto">
        <h2 class="text-xl font-bold mb-4">Biodata Anggota:</h2>
        <ul>
            <li class="mb-2">
                <div class="flex flex-col">
                    <span class="font-bold">Mirza Radithya Ramadhana </span>
                    <span>NPM: 2406405563</span>
                    <span>Jurusan: Ilmu Komputer</span>
                </div>
            </li>
            <li class="mb-2">
                <div class="flex flex-col">
                    <span class="font-bold">Mafaza Ananda Rahman</span>
                    <span>NPM: 2406401306</span>
                    <span>Jurusan: Sistem Informasi</span>
                </div>
            </li>
            <li class="mb-2">
                <div class="flex flex-col">
                    <span class="font-bold">Prasetya Surya Syahputra</span>
                    <span>NPM: 2406398381</span>
                    <span>Jurusan: Ilmu Komputer</span>
                </div>
            </li>
            <li class="mb-2">
                <div class="flex flex-col">
                    <span class="font-bold">William Jonnatan</span>
                    <span>NPM: 2406429020</span>
                    <span>Jurusan: Ilmu Komputer</span>
                </div>
            </li>
        </ul>

        <hr class="my-6">

        <% if (!user) { %>
            <p class="text-red-500 mb-4">Anda belum login.</p>
        <% } else { %>
            <p class="text-green-600 mb-4">Halo, <%= user.displayName %>!</p>
            <% if (user.isWhitelisted) { %>
                <div class="p-4 bg-yellow-100 border-l-4 border-yellow-500 rounded">
                    <p class="font-bold text-yellow-700">Panel Edit Tersedia</p>
                    <p class="text-sm text-gray-700 mt-1">
                        Anda termasuk whitelist, jadi panel edit ditampilkan.
                    </p>

                    <form id="theme-form" class="mt-4 space-y-3">
                        <div>
                            <label for="background" class="block text-sm text-gray-700 mb-1">Warna background</label>
                            <select id="background" name="background" class="w-full rounded border border-gray-300 px-2 py-1 text-sm">
                                <option value="bg-gray-100" <%= theme.background === 'bg-gray-100' ? 'selected' : '' %>>Gray</option>
                                <option value="bg-slate-200" <%= theme.background === 'bg-slate-200' ? 'selected' : '' %>>Slate</option>
                                <option value="bg-blue-100" <%= theme.background === 'bg-blue-100' ? 'selected' : '' %>>Blue</option>
                                <option value="bg-green-100" <%= theme.background === 'bg-green-100' ? 'selected' : '' %>>Green</option>
                                <option value="bg-yellow-100" <%= theme.background === 'bg-yellow-100' ? 'selected' : '' %>>Yellow</option>
                            </select>
                        </div>

                        <div>
                            <label for="font" class="block text-sm text-gray-700 mb-1">Jenis font</label>
                            <select id="font" name="font" class="w-full rounded border border-gray-300 px-2 py-1 text-sm">
                                <option value="font-sans" <%= theme.font === 'font-sans' ? 'selected' : '' %>>Sans</option>
                                <option value="font-serif" <%= theme.font === 'font-serif' ? 'selected' : '' %>>Serif</option>
                                <option value="font-mono" <%= theme.font === 'font-mono' ? 'selected' : '' %>>Mono</option>
                            </select>
                        </div>

                        <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded">
                            Simpan Tema
                        </button>
                        <p id="theme-message" class="text-sm"></p>
                    </form>
                </div>
            <% } else { %>
                <div class="p-4 bg-gray-100 border-l-4 border-gray-400 rounded">
                    <p class="font-semibold text-gray-700">Akses edit tidak tersedia</p>
                    <p class="text-sm text-gray-600 mt-1">
                        Anda berhasil login, tetapi email Anda tidak ada di whitelist.
                    </p>
                </div>
            <% } %>
        <% } %>
    </div>

    <% if (user && user.isWhitelisted) { %>
    <script>
        const themeForm = document.getElementById('theme-form');
        const themeMessage = document.getElementById('theme-message');

        themeForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const background = document.getElementById('background').value;
            const font = document.getElementById('font').value;

            const response = await fetch('/api/theme', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ background, font })
            });

            const result = await response.json();

            if (!response.ok) {
                themeMessage.className = 'text-sm text-red-600';
                themeMessage.textContent = result.message || 'Gagal menyimpan theme';
                return;
            }

            document.body.classList.remove('bg-gray-100', 'bg-slate-200', 'bg-blue-100', 'bg-green-100', 'bg-yellow-100');
            document.body.classList.remove('font-sans', 'font-serif', 'font-mono');
            document.body.classList.add(background, font);

            themeMessage.className = 'text-sm text-green-700';
            themeMessage.textContent = result.message || 'Theme berhasil disimpan';
        });
    </script>
    <% } %>

</body>
</html>